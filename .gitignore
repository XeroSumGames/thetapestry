# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/worktrees/

# Reference rulebooks — kept local only because the PDFs are 90MB+
# and bloat the repo. Authoritative rules live here for pdftotext
# lookups (per CLAUDE.md). Restore via `git cat-file -p <blob-hash>`
# from a stash if missing — they were last preserved in stash@{0}'s
# untracked-files commit (ecd7cb2 on 2026-04-27).
docs/Rules/
